# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.rs text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Cargo lock files
Cargo.lock text eol=lf

# Python requirements
requirements*.txt text eol=lf
pyproject.toml text eol=lf
uv.lock text eol=lf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf
README text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.pckl binary

@startuml "Infraware Terminal - Architecture Overview"
title "Infraware Terminal - High-Level Architecture"

' System components
package "Terminal" {
  class TerminalState {
    + output: OutputBuffer
    + input: InputBuffer
    + history: CommandHistory
    + mode: TerminalMode
    --
    + add_output(line: String)
    + submit_input(): String
    + insert_char(c: char)
  }

  class TerminalMode <<enum>> {
    Normal
    ExecutingCommand
    WaitingLLM
    PromptingInstall
  }

  class EventHandler {
    + poll_event(): TerminalEvent
    - handle_keyboard_event()
  }
}

package "Input Classification (SCAN Algorithm)" {
  class InputClassifier {
    - chain: ClassifierChain
    --
    + classify(input: &str): Result<InputType>
    + new(): Self
  }

  class InputType <<enum>> {
    Command { command, args, original_input }
    NaturalLanguage(String)
    Empty
    CommandTypo { input, suggestion, distance }
  }

  class ClassifierChain {
    - handlers: Vec<Box<dyn InputHandler>>
    --
    + process(input: &str): Option<InputType>
    + add_handler(Box<dyn InputHandler>): Self
  }

  interface InputHandler {
    + handle(input: &str): Option<InputType>
    + name(): &str
  }
}

package "Execution" {
  class CommandOrchestrator {
    - executor: CommandExecutor
    - facade: CommandExecutionFacade
    --
    + execute_command(cmd, args): Result<>
    + handle_installation_prompt()
  }

  class CommandExecutor {
    + execute(cmd, args, original_input): Result<CommandOutput>
    + command_exists(cmd): bool
    - execute_with_timeout()
  }

  class CommandExecutionFacade {
    - installer: PackageInstaller
    --
    + execute_with_fallback(): Result<ExecutionResult>
    + execute_or_install(auto_install): Result<ExecutionResult>
  }

  enum ExecutionResult {
    Success(CommandOutput)
    CommandNotFound { command, can_install, package_manager }
    ExecutionError { command, error }
  }

  class CommandOutput {
    + stdout: String
    + stderr: String
    + exit_code: i32
    --
    + is_success(): bool
  }
}

package "Natural Language" {
  class NaturalLanguageOrchestrator {
    - llm_client: Box<dyn LLMClientTrait>
    - renderer: ResponseRenderer
    --
    + query_llm(text: &str): Result<String>
    + render_response(response: &str): String
  }

  interface LLMClientTrait {
    + query(text: &str): Result<String>
    + query_with_context(): Result<String>
  }

  class HttpLLMClient {
    - base_url: String
    - client: reqwest::Client
  }

  class MockLLMClient {
    + query(): Result<String>
  }

  class ResponseRenderer {
    + highlight_code(code, language): String
    + format_markdown(text): String
  }
}

package "Package Management" {
  class PackageInstaller {
    - package_manager: Box<dyn PackageManager>
    --
    + install_package(name): Result<>
    + detect_package_manager(): Box<dyn PackageManager>
  }

  interface PackageManager {
    + name(): &str
    + is_available(): bool
    + install(package): Result<>
    + priority(): u8
  }

  class AptPackageManager
  class YumPackageManager
  class DnfPackageManager
  class PacmanPackageManager
  class BrewPackageManager
  class ChocoPackageManager
  class WingetPackageManager
}

' Relationships - Main Flow
TerminalState --> EventHandler : uses
InputClassifier --> InputType : returns
InputClassifier --> ClassifierChain : uses
ClassifierChain --> InputHandler : contains

TerminalState --> CommandOrchestrator : for commands
TerminalState --> NaturalLanguageOrchestrator : for NL queries

CommandOrchestrator --> CommandExecutor : executes via
CommandOrchestrator --> CommandExecutionFacade : uses
CommandExecutor --> CommandOutput : returns
CommandExecutionFacade --> PackageInstaller : uses for install

PackageInstaller --> PackageManager : selects best
HttpLLMClient ..|> LLMClientTrait : implements
MockLLMClient ..|> LLMClientTrait : implements
NaturalLanguageOrchestrator --> LLMClientTrait : queries via
NaturalLanguageOrchestrator --> ResponseRenderer : formats with

AptPackageManager ..|> PackageManager : implements
YumPackageManager ..|> PackageManager : implements
DnfPackageManager ..|> PackageManager : implements
PacmanPackageManager ..|> PackageManager : implements
BrewPackageManager ..|> PackageManager : implements
ChocoPackageManager ..|> PackageManager : implements
WingetPackageManager ..|> PackageManager : implements

note right of InputClassifier
  **SCAN Algorithm**
  Chain of Responsibility pattern
  with 7 handlers for optimal
  command vs NL classification
end note

note right of CommandExecutionFacade
  **Facade Pattern**
  Simplifies command execution
  with automatic error handling
  and installation fallback
end note

note right of PackageInstaller
  **Strategy Pattern**
  Supports 7 package managers:
  - Linux: apt, yum, dnf, pacman
  - macOS: brew
  - Windows: choco, winget
end note

@enduml

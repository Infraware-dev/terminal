@startuml "Background Command Execution Sequence"
title "Background Command Execution: Sequence Diagram"

actor User
participant "Event Loop" as EventLoop
participant "CommandOrchestrator" as Orchestrator
participant "InputClassifier" as Classifier
participant "CommandExecutor" as Executor
participant "JobManager" as JobMgr
database "jobs: HashMap" as JobTable
participant "TokioProcess" as TokioProc
participant "TerminalState" as State

' ==================== INITIAL INPUT ====================

User -> EventLoop: Type "sleep 30 &"
EventLoop -> Classifier: classify("sleep 30 &")
Classifier --> EventLoop: InputType::Command{\n  cmd: "sleep",\n  args: ["30"],\n  original_input: Some("sleep 30 &")\n}

' ==================== BACKGROUND COMMAND DETECTION ====================

EventLoop -> Orchestrator: handle_command(\n  cmd="sleep", args=["30"],\n  original_input="sleep 30 &",\n  state, ui, job_manager)

Orchestrator -> Executor: is_background_command("sleep 30 &")
activate Executor
  note right of Executor
    Check if input:
    - Ends with "&" (yes)
    - NOT ends with "&&" (correct)
    - "&" not in quotes (not quoted)
    Returns: true
  end note
Executor --> Orchestrator: true

' ==================== BACKGROUND EXECUTION ====================

Orchestrator -> Orchestrator: Calls execute_background_and_display()

Orchestrator -> Executor: execute_background(\n  "sleep 30 &",\n  job_manager)

activate Executor
  note right of Executor
    1. Remove trailing "&"
    2. Command becomes: "sleep 30"
  end note

  Executor -> TokioProc: TokioCommand::new("bash")\n  .arg("-c")\n  .arg("sleep 30")\n  .spawn()
  activate TokioProc
    TokioProc --> Executor: Child { id: Some(12345), ... }
  deactivate TokioProc

  note right of Executor
    3. Get PID from child.id()
    PID = 12345
  end note

  Executor -> JobMgr: write()
  activate JobMgr
    note right of JobMgr
      Acquire write lock (exclusive)
      May wait if read lock held
    end note

    Executor -> JobMgr: add_job(\n  "sleep 30 &",\n  12345,\n  child)

    activate JobMgr
      JobMgr -> JobMgr: id = next_id (1)
      JobMgr -> JobMgr: next_id += 1 (now 2)

      JobMgr -> JobTable: jobs.insert(\n  1,\n  JobEntry {\n    info: JobInfo {\n      id: 1,\n      pid: 12345,\n      command: "sleep 30 &",\n      status: Running,\n      start_time: now()\n    },\n    child: child\n  })
      activate JobTable
      JobTable --> JobMgr: ()
      deactivate JobTable

      JobMgr --> Executor: 1 (job_id)
    deactivate JobMgr

  deactivate JobMgr

  note right of Executor
    4. Return (job_id=1, pid=12345)
  end note

  Executor --> Orchestrator: Ok((1, 12345))
deactivate Executor

' ==================== DISPLAY FEEDBACK ====================

note right of Orchestrator
  Format and display feedback
end note

Orchestrator -> State: add_output(\n  "[1] sleep 30 & (PID: 12345)")

State --> Orchestrator: ()

Orchestrator --> EventLoop: Ok(())

EventLoop -> EventLoop: Render terminal UI
note right of EventLoop
  User sees:
  [1] sleep 30 & (PID: 12345)

  Terminal prompt returns immediately
end note

' ==================== CONTINUOUS MONITORING ====================

rect rgb(200, 220, 255)
  note over EventLoop, JobMgr: PERIODIC JOB MONITORING (JOB_CHECK_INTERVAL = 250ms)

  par "User Interacts with Terminal"
    User -> EventLoop: Type other commands
    EventLoop -> EventLoop: Process events normally
  and "Background Job Monitoring (Periodic, not per-event)"
    loop Every JOB_CHECK_INTERVAL (250ms)
      alt Check if enough time has elapsed
        note right of EventLoop
          Track: last_job_check: Instant
          Current: Instant::now()
          If elapsed >= JOB_CHECK_INTERVAL {
            call check_completed_jobs()
            last_job_check = Instant::now()
          }
        end note

        EventLoop -> EventLoop: call check_completed_jobs()

        EventLoop -> JobMgr: read() for has_running_jobs check
        activate JobMgr
          note right of JobMgr
            **Fast Path: Read Lock First**
            Check if ANY jobs exist before
            acquiring expensive write lock
          end note

          EventLoop -> JobMgr: has_running_jobs()
          activate JobMgr
            alt No jobs exist
              JobMgr --> EventLoop: false
              deactivate JobMgr
              note right of EventLoop
                Skip expensive write lock
                Return early
              end note
            else Jobs exist, proceed
              JobMgr --> EventLoop: true
              deactivate JobMgr
            end

        deactivate JobMgr

        EventLoop -> JobMgr: write() for status checking
        activate JobMgr
          note right of JobMgr
            **Acquire Write Lock**
            Only after confirming jobs exist
          end note

          EventLoop -> JobMgr: check_completed()
          activate JobMgr
            note right of JobMgr
              For each job in jobs HashMap:
              1. Try non-blocking wait via try_wait()
              2. No wait blocking the UI!
            end note

            JobMgr -> TokioProc: try_wait()
            activate TokioProc
              alt Process still running
                TokioProc --> JobMgr: Ok(None)
                note right of JobMgr
                  Job still running
                  Status stays Running
                end note
              else Process completed
                TokioProc --> JobMgr: Ok(Some(status))
                deactivate TokioProc

                note right of JobMgr
                  Process has completed
                  Extract exit code
                end note

                JobMgr -> JobMgr: status = Done(0)
                JobMgr -> JobMgr: Mark for removal
              end

            alt Job completed during this check
              JobMgr -> JobTable: jobs.remove(1)
              activate JobTable
              JobTable --> JobMgr: Some(JobEntry)
              deactivate JobTable

              note right of JobMgr
                Add to completed list
              end note

              JobMgr --> EventLoop: Vec<JobInfo> {\n  JobInfo {\n    id: 1,\n    pid: 12345,\n    command: "sleep 30 &",\n    status: Done(0),\n    start_time: ...\n  }\n}
            else Job still running
              JobMgr --> EventLoop: Vec<JobInfo> {}
            end

          deactivate JobMgr
        deactivate JobMgr

        EventLoop -> State: Display completion messages
        State --> EventLoop: ()

        EventLoop -> EventLoop: Render terminal with updates
      end
    end
  end
end

' ==================== MANUAL JOB LISTING ====================

rect rgb(200, 255, 200)
  note over EventLoop, JobMgr: USER REQUESTS JOB LIST

  User -> EventLoop: Type "jobs"
  EventLoop -> Classifier: classify("jobs")
  Classifier --> EventLoop: InputType::Command

  EventLoop -> Orchestrator: handle_command("jobs", ...)

  Orchestrator -> Orchestrator: Detect "jobs" builtin

  Orchestrator -> JobMgr: read()
  activate JobMgr
    note right of JobMgr
      Acquire read lock
      Many readers can acquire simultaneously
    end note

    Orchestrator -> JobMgr: list_jobs()
    activate JobMgr
      note right of JobMgr
        Iterate through jobs HashMap
        Clone all JobInfo entries
        No modification, safe for reading
      end note

      JobMgr --> Orchestrator: Vec<JobInfo> [
        JobInfo { id: 2, pid: 12346, ... },
        JobInfo { id: 3, pid: 12347, ... }
      ]
    deactivate JobMgr
  deactivate JobMgr

  note right of Orchestrator
    Format and display each job:
    [2] some_command (PID: 12346) Running
    [3] another_cmd (PID: 12347) Done (exit: 0)
  end note

  Orchestrator -> State: add_output(formatted jobs)
  State --> Orchestrator: ()

  Orchestrator --> EventLoop: Ok(())
  EventLoop -> EventLoop: Render UI with jobs list
end

' ==================== NOTES ====================

note over EventLoop
  **Key Design Points**

  1. **Periodic Job Checking (250ms Interval)**
     - JOB_CHECK_INTERVAL = Duration::from_millis(250)
     - Checked via last_job_check: Instant tracking
     - Balances responsiveness vs lock contention
     - Users perceive <300ms as "instant"
     - Avoids lock acquisition on every keystroke

  2. **Non-Blocking Status Check**
     - try_wait() is non-blocking
     - Doesn't freeze the UI
     - Perfect for periodic event loop polling

  3. **Lock Granularity with Fast Path**
     - First acquire read lock: check has_running_jobs()
     - Only acquire write lock if jobs exist
     - Reduces unnecessary lock contention on quiet periods
     - Multiple readers for list_jobs

  4. **Fail-Fast Lock Poisoning**
     - If RwLock poisoned, log error and return early
     - Don't recover with .into_inner() (avoid corrupted state)
     - Prevents cascade failures from panics in locked sections
     - Graceful degradation: skip job check, continue UI responsiveness

  5. **RAII Safety**
     - Child process dropped with JobEntry removal
     - Automatic cleanup of resources

  6. **Clone-Based Display**
     - JobInfo is cloneable
     - Safe to display without holding locks
     - No long-duration lock contention

  7. **Immediate Feedback on Spawn**
     - "sleep 30 &" returns immediately
     - No waiting for job completion
     - User can type more commands right away

  8. **Automatic Cleanup**
     - Completed jobs removed from manager
     - Memory doesn't grow unbounded
     - Only active jobs consume resources
end note

@enduml

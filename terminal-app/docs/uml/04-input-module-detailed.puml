@startuml "Input Module - Detailed Architecture"
title "Input Module: Command Classification and Support Systems"

package "Core Classification" {
  class InputClassifier {
    - chain: ClassifierChain
    --
    + new(): Self
    + with_chain(chain: ClassifierChain): Self
    + classify(input: &str): Result<InputType>
  }

  class InputType <<enum>> {
    Command { command: String, args: Vec<String>, original_input: Option<String> }
    NaturalLanguage(String)
    Empty
    CommandTypo { input: String, suggestion: String, distance: usize }
  }

  class ClassifierChain {
    - handlers: Vec<Box<dyn InputHandler>>
    --
    + new(): Self
    + add_handler(handler): Self
    + process(input: &str): Option<InputType>
  }

  interface InputHandler {
    + handle(input: &str): Option<InputType>
    + name(): &str
  }

  InputClassifier --> ClassifierChain
  ClassifierChain --> InputHandler
  InputClassifier --> InputType
}

package "Handler Chain (7 Handlers)" {
  class EmptyInputHandler
  class PathCommandHandler
  class KnownCommandHandler
  class CommandSyntaxHandler
  class TypoDetectionHandler
  class NaturalLanguageHandler
  class DefaultHandler

  EmptyInputHandler ..|> InputHandler
  PathCommandHandler ..|> InputHandler
  KnownCommandHandler ..|> InputHandler
  CommandSyntaxHandler ..|> InputHandler
  TypoDetectionHandler ..|> InputHandler
  NaturalLanguageHandler ..|> InputHandler
  DefaultHandler ..|> InputHandler
}

package "Support Systems" {
  class CompiledPatterns {
    - question_word_regex: Regex
    - article_regex: Regex
    - nl_indicator_regex: Regex
    --
    + get(): &'static CompiledPatterns
    + has_natural_language_indicators(input): bool
    + starts_with_question_word(input): bool
    + has_articles(input): bool
    + has_shell_operators(input): bool
  }

  class CommandCache {
    - available: HashSet<String>
    - unavailable: HashSet<String>
    - aliases: HashMap<String, String>
    --
    + is_available(command: &str): bool
    + load_aliases()
    + clear_cache()
  }

  class CommandParser {
    + parse(input: &str): Result<Vec<String>>
    + split_args(input: &str): Result<Vec<String>>
  }
}

note top of CompiledPatterns
  **Precompiled RegexSet Patterns**
  - Compiled once at startup
  - 10-100x faster than repeated compilation
  - Uses once_cell::Lazy for thread-safe singleton
  - Supports multilingual patterns

  **Patterns Included**
  - Question markers and indicators
  - Articles (English, Italian, Spanish, French, German)
  - Shell operators (|, >, <, &&, ||)
end note

note top of CommandCache
  **Lazy Singleton with RwLock**
  - Global static COMMAND_CACHE
  - Read lock for cache hits (fast path)
  - Write lock for cache misses (slow path)
  - Uses `which` crate for PATH lookup

  **Performance**
  - Hit: O(1) hash lookup
  - Miss: O(PATH_length) via which
  - Typical: 99% read-heavy workload
end note

note top of CommandParser
  **Shell Parsing**
  - Uses shell_words crate
  - Handles quoted strings
  - Preserves escape sequences
  - Fallback for syntax errors
end note

KnownCommandHandler --> CommandCache : uses
PathCommandHandler --> CommandParser : uses
CommandSyntaxHandler --> CompiledPatterns : uses
NaturalLanguageHandler --> CompiledPatterns : uses
TypoDetectionHandler --> CommandCache : queries

' Typo Detection Details
package "Typo Detection (Handler 5)" {
  class TypoDetectionHandler {
    - known_commands: Vec<String>
    - max_distance: usize
    --
    + new(commands, max_distance): Self
    + with_defaults(): Self
    + find_closest_match(input): Option<(String, usize)>
    + looks_like_command(input): bool
    + is_unknown_command(word): bool
  }

  class LevenshteinDistance {
    + calculate(s1: &str, s2: &str): usize
  }

  note right of TypoDetectionHandler
    **Levenshtein Distance Algorithm**
    Max distance threshold: 2 (default)

    **Examples**
    - "dokcer" -> "docker" (dist=2)
    - "kubeclt" -> "kubectl" (dist=1)
    - "ls" -> "ls" (not typo, passes)

    **Filtering**
    - Only checks unknown commands
    - Filters long phrases (> 5 words)
    - Skips input with ? or !
    - Skips content with articles
  end note

  TypoDetectionHandler --> LevenshteinDistance : uses
}

' Handler Chain Details
package "Handler Chain Details" as ChainDetails {
  note as h1note
    **Handler 1: EmptyInputHandler**
    O(1) check for empty/whitespace
    Returns InputType::Empty
  end note

  note as h2note
    **Handler 2: PathCommandHandler**
    - Detects: /, ./, ../
    - Checks: is_executable()
    - Platform-specific: Unix vs Windows
    - Preserves original for shell ops
  end note

  note as h3note
    **Handler 3: KnownCommandHandler**
    - 60+ DevOps commands whitelist
    - Verifies PATH via CommandCache
    - Returns Command with parsed args
    - Falls through if not installed
  end note

  note as h4note
    **Handler 4: CommandSyntaxHandler**
    - Detects: flags (-f, --flag)
    - Detects: pipes, redirects
    - Detects: $VAR, ${VAR}
    - Detects: short words
    - Assumes looks_like_command=true
  end note

  note as h5note
    **Handler 5: TypoDetectionHandler**
    - Prevents false NL classification
    - Only checks unknown commands
    - Levenshtein distance <= 2
    - Returns CommandTypo with suggestion
  end note

  note as h6note
    **Handler 6: NaturalLanguageHandler**
    - Precompiled regex patterns
    - Multilingual support
    - Question words detection
    - Article-based heuristics
    - Long phrase detection (>5 words)
  end note

  note as h7note
    **Handler 7: DefaultHandler**
    - Fallback catch-all
    - Treats as NaturalLanguage
    - Should never fail
  end note
}

' Input flow diagram
package "Input Flow" {
  rectangle "User Input" as input
  rectangle "1. Empty?" as c1
  rectangle "2. Path?" as c2
  rectangle "3. Known Cmd?" as c3
  rectangle "4. Cmd Syntax?" as c4
  rectangle "5. Typo?" as c5
  rectangle "6. NL Pattern?" as c6
  rectangle "7. Default (NL)" as c7

  input --> c1
  c1 -->|No| c2
  c1 -->|Yes| EmptyInputHandler : returns Empty
  c2 -->|No| c3
  c2 -->|Yes| PathCommandHandler : returns Command
  c3 -->|No| c4
  c3 -->|Yes| KnownCommandHandler : returns Command
  c4 -->|No| c5
  c4 -->|Yes| CommandSyntaxHandler : returns Command
  c5 -->|No| c6
  c5 -->|Yes| TypoDetectionHandler : returns CommandTypo
  c6 -->|No| c7
  c6 -->|Yes| NaturalLanguageHandler : returns NL
  c7 --> DefaultHandler : returns NL
}

@enduml

@startuml "Executor Module with Background Support"
title "Executor Module: Enhanced with Background Process Support"

' ==================== CORE EXECUTION ====================

package "Command Execution" {
  class CommandOutput {
    + stdout: String
    + stderr: String
    + exit_code: i32
    --
    + is_success(): bool
    + combined_output(): String
  }

  class CommandExecutor {
    --
    ' Foreground execution
    + execute(cmd: &str, args: &[String], original_input: Option<&str>) -> Result<CommandOutput>
    + execute_interactive(cmd: &str, args: &[String], ui: &mut TerminalUI) -> Result<CommandOutput>
    + execute_sudo(cmd: &str, args: &[String]) -> Result<CommandOutput>
    --
    ' Background command support (NEW)
    + is_background_command(input: &str) -> bool
    + execute_background(cmd: &str, job_manager: &SharedJobManager) -> Result<(usize, u32)>
    --
    ' Helpers
    + command_exists(cmd: &str): bool
    + requires_interactive(cmd: &str): bool
    - get_platform_shell(): (&'static str, &'static str)
    - is_shell_builtin(cmd: &str): bool
    - is_interactive_command(cmd: &str): bool
  }

  note top of CommandExecutor
    **Foreground vs Background Execution**

    **Foreground (execute)**
    - Waits for completion with timeout (5 min)
    - Captures stdout/stderr
    - Returns CommandOutput with exit code
    - Suitable for most commands

    **Interactive (execute_interactive)**
    - Suspends TUI to provide real TTY
    - No output capture
    - Ideal for editors (vim, nano)
    - Unix/Linux/macOS only

    **Background (execute_background) [NEW]**
    - Spawns process, returns immediately
    - Returns (job_id, pid)
    - No output capture (output goes to terminal)
    - Process tracked by JobManager
    - Ideal for long-running tasks
  end note

  CommandExecutor --> CommandOutput : returns
}

' ==================== JOB MANAGEMENT ====================

package "Job Management (NEW)" {
  enum JobStatus {
    Running
    Done(i32)
    Terminated
  }

  class JobInfo {
    + id: usize
    + pid: u32
    + command: String
    + status: JobStatus
    + start_time: Instant
  }

  class JobManager {
    - jobs: HashMap<usize, JobEntry>
    - next_id: usize
    --
    + new(): Self
    + add_job(command: String, pid: u32, child: Child) -> usize
    + list_jobs(): Vec<JobInfo>
    + job_count(): usize
    + check_completed() -> Vec<JobInfo>
    + remove_job(id: usize) -> Option<JobInfo>
    + has_running_jobs(): bool
  }

  note right of JobManager
    **Job Lifecycle Management**

    add_job():
    - Assigns 1-based ID
    - Stores Job in HashMap
    - Returns assigned ID

    check_completed():
    - Non-blocking try_wait() on all jobs
    - Updates status from Done/Terminated
    - Removes and returns completed jobs
    - No blocking - safe for event loop

    list_jobs():
    - Returns cloned JobInfo for display
    - No modification, read-safe
    - Multiple readers can call simultaneously
  end note

  class SharedJobManager {
    ' Type alias visualization
    note as SharedNote
      type SharedJobManager = Arc<RwLock<JobManager>>

      **Thread-Safe Sharing**
      - Arc: shared ownership
      - RwLock: reader-writer synchronization
      - Many readers, exclusive writers
    end note
  }

  JobManager --> JobInfo : returns cloned
  JobManager --> JobStatus : tracks via
  CommandExecutor --> JobManager : adds jobs to
}

' ==================== BACKGROUND COMMAND DETECTION ====================

package "Background Command Detection (NEW)" {
  class BackgroundCommandValidator {
    - Trailing "&" detection
    - Quote handling
    - Escape sequence parsing
  }

  note right of BackgroundCommandValidator
    **is_background_command Logic**

    Valid Background:
    - "sleep 10 &" ✓
    - "echo hello &" ✓
    - "cmd1; cmd2 &" ✓

    Invalid (Not Background):
    - "cmd1 && cmd2" ✗ (double ampersand)
    - "echo 'a & b'" ✗ (quoted)
    - "echo hello \\&" ✗ (escaped)
    - "echo hello" ✗ (no trailing &)

    **Algorithm**
    1. Trim input
    2. Check ends with "&" but not "&&"
    3. Parse quotes and escapes
    4. Return true if unquoted trailing "&"
  end note

  CommandExecutor --> BackgroundCommandValidator : uses
}

' ==================== PACKAGE MANAGEMENT (EXISTING) ====================

package "Package Management Strategy" {
  interface PackageManager {
    + name(): &str
    + is_available(): bool
    + install(package: &str): Result<()>
    + priority(): u8
  }

  class AptPackageManager
  class YumPackageManager
  class DnfPackageManager
  class PacmanPackageManager
  class BrewPackageManager
  class ChocoPackageManager
  class WingetPackageManager

  class PackageInstaller {
    - package_manager: Box<dyn PackageManager>
    --
    + new(): Self
    + install_package(name: &str): Result<()>
    + detect_package_manager(): Box<dyn PackageManager>
    + is_available(): bool
  }

  AptPackageManager ..|> PackageManager
  YumPackageManager ..|> PackageManager
  DnfPackageManager ..|> PackageManager
  PacmanPackageManager ..|> PackageManager
  BrewPackageManager ..|> PackageManager
  ChocoPackageManager ..|> PackageManager
  WingetPackageManager ..|> PackageManager

  PackageInstaller --> PackageManager : selects best

  note right of PackageInstaller
    **Strategy Pattern for Package Managers**
    Selects best available:
    1. brew (macOS, priority=90)
    2. winget (Windows, priority=85)
    3. apt (Debian, priority=80)
    4. dnf/yum/pacman (Linux variants)
    5. choco (Windows fallback, priority=70)
  end note
}


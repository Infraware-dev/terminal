@startuml "Complete System - Class Diagram"
title "Infraware Terminal: Complete System Class Diagram"

' ========== INPUT CLASSIFICATION ==========
package "Input Classification" as InputPkg {
  class InputClassifier {
    - chain: ClassifierChain
    --
    + classify(input: &str): Result<InputType>
    + new(): Self
  }

  enum InputType {
    Command { command: String, args: Vec<String>, original_input: Option<String> }
    NaturalLanguage(String)
    Empty
    CommandTypo { input: String, suggestion: String, distance: usize }
  }

  interface InputHandler {
    + handle(input: &str): Option<InputType>
    + name(): &str
  }

  class ClassifierChain {
    - handlers: Vec<Box<dyn InputHandler>>
    --
    + process(input: &str): Option<InputType>
    + add_handler(handler): Self
  }

  class EmptyInputHandler
  class PathCommandHandler
  class KnownCommandHandler
  class CommandSyntaxHandler
  class TypoDetectionHandler
  class NaturalLanguageHandler
  class DefaultHandler

  EmptyInputHandler ..|> InputHandler
  PathCommandHandler ..|> InputHandler
  KnownCommandHandler ..|> InputHandler
  CommandSyntaxHandler ..|> InputHandler
  TypoDetectionHandler ..|> InputHandler
  NaturalLanguageHandler ..|> InputHandler
  DefaultHandler ..|> InputHandler

  class CompiledPatterns <<(S,#FF7700)>>
  class CommandCache <<(S,#FF7700)>>
  class CommandParser

  InputClassifier --> ClassifierChain
  ClassifierChain --> InputHandler
  KnownCommandHandler --> CommandCache
  NaturalLanguageHandler --> CompiledPatterns
  PathCommandHandler --> CommandParser
  CommandSyntaxHandler --> CompiledPatterns
}

' ========== COMMAND EXECUTION ==========
package "Command Execution" as ExecutorPkg {
  class CommandExecutor {
    + execute(cmd, args, original_input): Result<CommandOutput>
    + command_exists(cmd): bool
    + execute_sudo(cmd, args): Result<CommandOutput>
  }

  class CommandOutput {
    + stdout: String
    + stderr: String
    + exit_code: i32
    --
    + is_success(): bool
    + combined_output(): String
  }

  class CommandExecutionFacade {
    - installer: PackageInstaller
    --
    + execute_with_fallback(cmd, args): Result<ExecutionResult>
    + execute_or_install(cmd, args, auto_install): Result<ExecutionResult>
    + is_command_available(cmd): bool
  }

  enum ExecutionResult {
    Success(CommandOutput)
    CommandNotFound { command, can_install, package_manager }
    ExecutionError { command, error }
  }

  CommandExecutor --> CommandOutput
  CommandExecutionFacade --> ExecutionResult
  CommandExecutionFacade --> CommandExecutor
  CommandExecutor --> CommandCache
}

' ========== PACKAGE MANAGEMENT ==========
package "Package Management" as PackagePkg {
  interface PackageManager {
    + name(): &str
    + is_available(): bool
    + install(package): Result<()>
    + priority(): u8
  }

  class AptPackageManager
  class YumPackageManager
  class DnfPackageManager
  class PacmanPackageManager
  class BrewPackageManager
  class ChocoPackageManager
  class WingetPackageManager

  AptPackageManager ..|> PackageManager
  YumPackageManager ..|> PackageManager
  DnfPackageManager ..|> PackageManager
  PacmanPackageManager ..|> PackageManager
  BrewPackageManager ..|> PackageManager
  ChocoPackageManager ..|> PackageManager
  WingetPackageManager ..|> PackageManager

  class PackageInstaller {
    - package_manager: Box<dyn PackageManager>
    --
    + install_package(name): Result<()>
    + detect_package_manager(): Box<dyn PackageManager>
    + is_available(): bool
  }

  PackageInstaller --> PackageManager
  CommandExecutionFacade --> PackageInstaller
}

' ========== ORCHESTRATORS ==========
package "Orchestrators" as OrchestratorPkg {
  class CommandOrchestrator {
    - executor: CommandExecutor
    - facade: CommandExecutionFacade
    --
    + execute_command(cmd, args): Result<String>
  }

  class NaturalLanguageOrchestrator {
    - llm_client: Box<dyn LLMClientTrait>
    - renderer: ResponseRenderer
    --
    + query_llm(text): Result<String>
    + format_response(response): String
  }

  class TabCompletionHandler {
    - command_executor: CommandExecutor
    --
    + get_completions(input, cursor_pos): Vec<String>
  }

  CommandOrchestrator --> CommandExecutor
  CommandOrchestrator --> CommandExecutionFacade
  NaturalLanguageOrchestrator --> ResponseRenderer
}

' ========== LLM CLIENT ==========
package "LLM Integration" as LLMPkg {
  interface LLMClientTrait {
    + query(text): Result<String>
    + query_with_context(text, context): Result<String>
  }

  class HttpLLMClient {
    - base_url: String
    - client: reqwest::Client
    --
    + new(base_url): Self
  }

  class MockLLMClient {
    - responses: HashMap<String, String>
  }

  HttpLLMClient ..|> LLMClientTrait
  MockLLMClient ..|> LLMClientTrait

  class ResponseRenderer {
    + format_markdown(text): String
    + highlight_code(code, language): String
  }

  class SyntaxHighlighter {
    + highlight(code, language): String
  }

  ResponseRenderer --> SyntaxHighlighter
  NaturalLanguageOrchestrator --> LLMClientTrait
}

' ========== TERMINAL STATE ==========
package "Terminal State" as TerminalStatePkg {
  class TerminalState {
    + output: OutputBuffer
    + input: InputBuffer
    + history: CommandHistory
    + mode: TerminalMode
    --
    + add_output(line): void
    + submit_input(): String
  }

  enum TerminalMode {
    Normal
    ExecutingCommand
    WaitingLLM
    PromptingInstall
  }

  class OutputBuffer {
    - lines: Vec<String>
    - scroll_offset: usize
    --
    + add_line(line): void
    + scroll_up(): void
  }

  class InputBuffer {
    - text: String
    - cursor_pos: usize
    --
    + insert_char(c): void
    + delete_char(): void
  }

  class CommandHistory {
    - entries: Vec<String>
    - position: Option<usize>
    --
    + add(cmd): void
    + previous(): Option<String>
  }

  TerminalState --> OutputBuffer
  TerminalState --> InputBuffer
  TerminalState --> CommandHistory
  TerminalState --> TerminalMode
}

' ========== TUI RENDERING ==========
package "TUI Rendering" as TUIPkg {
  class TerminalTUI {
    - terminal: Terminal
    --
    + render(state): Result<()>
  }

  class EventHandler {
    + poll_event(timeout): Result<Option<TerminalEvent>>
  }

  enum TerminalEvent {
    KeyPressed { key, modifiers }
    MouseEvent { button, x, y }
    Resize { width, height }
  }

  TerminalTUI --> TerminalState
  EventHandler --> TerminalEvent
}

' ========== MAIN APPLICATION ==========
package "Main Application" as MainPkg {
  class InfrawareTerminal {
    - state: TerminalState
    - input_classifier: InputClassifier
    - command_orchestrator: CommandOrchestrator
    - nl_orchestrator: NaturalLanguageOrchestrator
    - event_handler: EventHandler
    - tui: TerminalTUI
    --
    + new(): Result<Self>
    + run(): Result<()>
    + handle_event(event): Result<()>
  }

  InfrawareTerminal --> TerminalState
  InfrawareTerminal --> InputClassifier
  InfrawareTerminal --> CommandOrchestrator
  InfrawareTerminal --> NaturalLanguageOrchestrator
  InfrawareTerminal --> TabCompletionHandler
  InfrawareTerminal --> EventHandler
  InfrawareTerminal --> TerminalTUI
}

' ========== CROSS-PACKAGE RELATIONSHIPS ==========
InputClassifier --> InputType : classifies to
CommandOrchestrator --> CommandExecutor : uses
CommandOrchestrator --> TerminalState : updates
NaturalLanguageOrchestrator --> TerminalState : updates
TabCompletionHandler --> TerminalState : updates

note top of InputPkg
  **SCAN Algorithm**
  Chain of Responsibility with 7 handlers:
  1. EmptyInputHandler
  2. PathCommandHandler
  3. KnownCommandHandler
  4. CommandSyntaxHandler
  5. TypoDetectionHandler
  6. NaturalLanguageHandler
  7. DefaultHandler
end note

note top of ExecutorPkg
  **Command Execution**
  - Facade pattern
  - Async/await with tokio
  - 5-minute timeout
  - Shell operator support
end note

note top of PackagePkg
  **Package Management**
  - Strategy pattern
  - 7 package managers
  - Priority-based selection
  - Cross-platform support
end note

note top of OrchestratorPkg
  **Workflow Orchestrators**
  Each handles one responsibility:
  - CommandOrchestrator: cmd execution
  - NLOrchestrator: LLM queries
  - TabCompletionHandler: completion
end note

note top of LLMPkg
  **LLM Integration**
  - Trait-based abstraction
  - Markdown rendering
  - Syntax highlighting
  - Multiple implementations
end note

note top of TerminalStatePkg
  **State Management**
  Single Responsibility:
  - OutputBuffer: scrollable output
  - InputBuffer: text editing
  - CommandHistory: navigation
end note

@enduml

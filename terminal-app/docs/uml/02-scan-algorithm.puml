@startuml "SCAN Algorithm - Chain of Responsibility Pattern"
title "SCAN Algorithm: Chain of Responsibility with 7 Handlers"

' Trait definition
interface InputHandler <<interface>> {
  + handle(input: &str): Option<InputType>
  + name(): &str
}

' Chain coordinator
class ClassifierChain {
  - handlers: Vec<Box<dyn InputHandler>>
  --
  + new(): Self
  + add_handler(Box<dyn InputHandler>): Self
  + process(input: &str): Option<InputType>
  + len(): usize
  + is_empty(): bool
}

' InputType enum
class InputType <<enum>> {
  Command { command: String, args: Vec<String>, original_input: Option<String> }
  NaturalLanguage(String)
  Empty
  CommandTypo { input: String, suggestion: String, distance: usize }
}

' Handler 1: Empty Input
class EmptyInputHandler {
  + new(): Self
  --
  + handle(input): Option<InputType>
}

EmptyInputHandler ..|> InputHandler : implements

' Handler 2: Path Commands
class PathCommandHandler {
  + new(): Self
  --
  + is_path(input): bool
  + is_executable(path): bool
  + parse_as_command(input): Result<InputType>
  + handle(input): Option<InputType>
}

PathCommandHandler ..|> InputHandler : implements

' Handler 3: Known Commands
class KnownCommandHandler {
  - known_commands: Vec<String>
  --
  + new(commands: Vec<String>): Self
  + with_defaults(): Self
  + is_known_command(input): bool
  + parse_as_command(input): Result<InputType>
  + add_command(String)
  + handle(input): Option<InputType>
}

KnownCommandHandler ..|> InputHandler : implements

note right of KnownCommandHandler
  **60+ DevOps Commands**
  - Basic shell: ls, cd, pwd, etc.
  - Text processing: grep, sed, awk
  - Process: ps, top, kill
  - Network: curl, ping, ssh
  - Docker: docker, docker-compose
  - K8s: kubectl, helm
  - Cloud: aws, az, gcloud
  - Git/VCS: git, svn
  - Build: npm, cargo, maven

  **PATH Verification**
  Uses CommandCache for fast
  O(1) lookups (99% read-heavy)
end note

' Handler 4: Command Syntax
class CommandSyntaxHandler {
  + new(): Self
  --
  + looks_like_command(input): bool
  + parse_as_command(input): Result<InputType>
  + handle(input): Option<InputType>
}

CommandSyntaxHandler ..|> InputHandler : implements

note right of CommandSyntaxHandler
  **Detects Command Syntax**
  - Flags: "-f", "--verbose"
  - Pipes: "|"
  - Redirects: ">", "<"
  - Env vars: "$VAR", "${VAR}"
  - Paths: "/", "./", "../"
  - Short words: < 20 chars
end note

' Handler 5: Typo Detection
class TypoDetectionHandler {
  - known_commands: Vec<String>
  - max_distance: usize
  --
  + new(commands, max_distance): Self
  + with_defaults(): Self
  + find_closest_match(input): Option<(String, usize)>
  + looks_like_command(input): bool
  + is_unknown_command(word): bool
  + handle(input): Option<InputType>
}

TypoDetectionHandler ..|> InputHandler : implements

note right of TypoDetectionHandler
  **Levenshtein Distance**
  Max distance = 2 (default)

  Prevents false NL classification:
  - "dokcer" -> "docker" (distance=2)
  - "kubeclt" -> "kubectl" (distance=1)
  - "grpe" -> "grep" (distance=2)

  Filters 5+ word phrases
  (likely natural language)
end note

' Handler 6: Natural Language
class NaturalLanguageHandler {
  + new(): Self
  --
  + is_likely_natural_language(input): bool
  + handle(input): Option<InputType>
}

NaturalLanguageHandler ..|> InputHandler : implements

note right of NaturalLanguageHandler
  **Precompiled RegexSet Patterns**
  10-100x faster than regex compilation

  **Multilingual Support**
  - English, Italian, Spanish
  - French, German

  **Detection Methods**
  1. Regex patterns (articles, indicators)
  2. Question words (how, what, etc.)
  3. Articles (the, a, un, el, etc.)
  4. Long phrases (> 5 words)
  5. Polite expressions (please, thanks)
  6. Request verbs (show, explain, help)
end note

' Handler 7: Default Handler
class DefaultHandler {
  + new(): Self
  --
  + handle(input): Option<InputType>
}

DefaultHandler ..|> InputHandler : implements

note right of DefaultHandler
  **Fallback Handler**
  Treats everything as
  natural language
  (catches any unmatched input)
end note

' InputClassifier orchestrator
class InputClassifier {
  - chain: ClassifierChain
  --
  + new(): Self
  + with_chain(chain): Self
  + classify(input): Result<InputType>
  + add_known_command(String)
}

InputClassifier --> ClassifierChain : creates
InputClassifier --> InputType : returns
ClassifierChain --> InputHandler : processes through

' Chain assembly visualization
package "Handler Chain Order (Optimized for Performance)" as ChainOrder {
  rectangle "1. Empty\nInput" as h1
  rectangle "2. Path\nCommands" as h2
  rectangle "3. Known\nCommands\n(cached)" as h3
  rectangle "4. Command\nSyntax" as h4
  rectangle "5. Typo\nDetection" as h5
  rectangle "6. Natural\nLanguage\n(precompiled)" as h6
  rectangle "7. Default\nHandler" as h7

  h1 --> h2 : pass
  h2 --> h3 : pass
  h3 --> h4 : pass
  h4 --> h5 : pass
  h5 --> h6 : pass
  h6 --> h7 : pass
}

ClassifierChain --> ChainOrder : implements

' Legend and notes
note top of ClassifierChain
  **Design Pattern: Chain of Responsibility**

  Each handler can:
  - Return Some(InputType) to classify
  - Return None to pass to next handler

  **Performance Optimizations**
  - Fast paths first (empty, paths)
  - Cached PATH lookups (RwLock)
  - Precompiled regex patterns
  - Short-circuit evaluation
end note

@enduml

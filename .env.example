# Engine type: rig (default) or mock
ENGINE_TYPE=rig

# Anthropic API key (required for rig engine; can also be passed via --api-key)
# ANTHROPIC_API_KEY=sk-...

# Rig engine config
ANTHROPIC_MODEL=claude-sonnet-4-20250514
RIG_MAX_TOKENS=4096
RIG_TIMEOUT_SECS=300
RIG_TEMPERATURE=0.7

# Memory system
MEMORY_PATH=./.infraware/memory.json
MEMORY_LIMIT=200

# Mock engine (optional)
# MOCK_WORKFLOW_FILE=path/to/workflow.json

# Logging
LOG_LEVEL=info
